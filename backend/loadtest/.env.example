BASE_URL=http://127.0.0.1:8000
TOKEN=replace-with-access-token

# 项目级读取接口需要填 PROJECT_ID
PROJECT_ID=replace-with-project-id

# 任务轮询二选一：
# 1. 直接填通用任务 ID，脚本会自动拼成 /api/tasks/{TASK_ID}
TASK_ID=
# 2. 或显式填任意任务状态路径，例如：
# /api/projects/<project_id>/workbench/tasks/<task_id>
# /api/creation/tasks/<task_id>
# /api/creation/videos/tasks/<task_id>
TASK_STATUS_PATH=

# 默认只压安全读接口；需要时再显式开启其它场景
ENABLE_PROJECT_READS=true
ENABLE_EPISODE_READS=true
ENABLE_STORYBOARD_READS=true
ENABLE_TASK_POLL=false
ENABLE_PROJECT_CREATE=false

# 读压测配置
READ_START_VUS=0
READ_STAGE1_VUS=20
READ_STAGE2_VUS=50
READ_STAGE3_VUS=100
READ_STAGE1_DURATION=30s
READ_STAGE2_DURATION=1m
READ_STAGE3_DURATION=1m
READ_RAMPDOWN_DURATION=20s
READ_SLEEP_SECONDS=1

# 任务轮询压测配置
TASK_POLL_VUS=20
TASK_POLL_DURATION=1m
TASK_POLL_SLEEP_SECONDS=2

# 写入压测配置
WRITE_RATE=1
WRITE_DURATION=30s
WRITE_PREALLOCATED_VUS=2
WRITE_MAX_VUS=10
WRITE_PROJECT_PREFIX=loadtest-project
